# Ollama configuration
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:3b

# Database location
# Default is memories.db in the project root.
# Change this to an absolute path to store the DB elsewhere (e.g., Dropbox for backup).
DB_PATH=

# Optional: upgrade to the 8B model for better metadata quality if you have 16GB+ RAM
# LLM_MODEL=llama3.2
